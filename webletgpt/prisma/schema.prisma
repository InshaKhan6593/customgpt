generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  chatSessions  ChatSession[]
  developerPlan DeveloperPlan?
  payouts       Payout[]
  sessions      Session[]
  subscriptions Subscription[]
  transactions  Transaction[]
  flows         UserFlow[]
  userPlan      UserPlan?
  weblets       Weblet[]       @relation("DeveloperWeblets")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Weblet {
  id                   String              @id @default(cuid())
  developerId          String
  name                 String
  slug                 String              @unique
  description          String?
  iconUrl              String?
  category             WebletCategory
  isActive             Boolean             @default(true)
  isPublic             Boolean             @default(false)
  rsilEnabled          Boolean             @default(false)
  rsilGovernance       Json?
  accessType           AccessType          @default(FREE)
  monthlyPrice         Float?
  stripePriceId        String?
  stripeProductId      String?
  capabilities         Json?
  privacyPolicy        String?
  conversationStarters Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  analyticsEvents      AnalyticsEvent[]
  chatSessions         ChatSession[]
  knowledgeFiles       KnowledgeFile[]
  developer            User                @relation("DeveloperWeblets", fields: [developerId], references: [id], onDelete: Cascade)
  childCompositions    WebletComposition[] @relation("ChildWeblet")
  parentCompositions   WebletComposition[] @relation("ParentWeblet")
  mcpServers           WebletMCPServer[]
  versions             WebletVersion[]

  @@index([developerId])
  @@index([category])
  @@index([isPublic, isActive])
}

model WebletVersion {
  id               String        @id @default(cuid())
  webletId         String
  versionNum       Int
  prompt           String
  status           VersionStatus @default(DRAFT)
  commitMsg        String?
  model            String        @default("anthropic/claude-3.5-sonnet")
  createdAt        DateTime      @default(now())
  openapiSchema    Json?
  isAbTest         Boolean       @default(false)
  abTestTrafficPct Int           @default(50)
  abTestStartedAt  DateTime?
  abTestEndedAt    DateTime?
  abTestWinner     Boolean?
  avgScore         Float?
  weblet           Weblet        @relation(fields: [webletId], references: [id], onDelete: Cascade)

  @@unique([webletId, versionNum])
}

model KnowledgeFile {
  id         String           @id @default(cuid())
  webletId   String
  filename   String
  fileSize   Int
  mimeType   String
  storageKey String           @unique
  createdAt  DateTime         @default(now())
  chunks     KnowledgeChunk[]
  weblet     Weblet           @relation(fields: [webletId], references: [id], onDelete: Cascade)
}

model KnowledgeChunk {
  id              String                 @id @default(cuid())
  knowledgeFileId String
  content         String
  embedding       Unsupported("vector")?
  knowledgeFile   KnowledgeFile          @relation(fields: [knowledgeFileId], references: [id], onDelete: Cascade)

  @@index([knowledgeFileId])
}

model UserFlow {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  mode           FlowMode @default(SEQUENTIAL)
  steps          Json
  masterWebletId String?
  isPublic       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  defaultPrompt  String?
  canvasState    Json?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebletComposition {
  id               String   @id @default(cuid())
  parentWebletId   String
  childWebletId    String
  triggerCondition String?
  passingContext   Json?
  createdAt        DateTime @default(now())
  childWeblet      Weblet   @relation("ChildWeblet", fields: [childWebletId], references: [id], onDelete: Cascade)
  parentWeblet     Weblet   @relation("ParentWeblet", fields: [parentWebletId], references: [id], onDelete: Cascade)

  @@unique([parentWebletId, childWebletId])
}

model ChatSession {
  id              String        @id @default(cuid())
  userId          String
  webletId        String
  title           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  langfuseTraceId String?
  messages        ChatMessage[]
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weblet          Weblet        @relation(fields: [webletId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([webletId])
}

model ChatMessage {
  id              String      @id @default(cuid())
  chatSessionId   String
  role            String
  content         String
  tokensUsed      Int?
  createdAt       DateTime    @default(now())
  langfuseTraceId String?
  chatSession     ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  webletId  String
  eventType String
  eventData Json?
  createdAt DateTime @default(now())
  weblet    Weblet   @relation(fields: [webletId], references: [id], onDelete: Cascade)

  @@index([webletId, createdAt])
  @@index([eventType])
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  status               SubStatus
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  currency        String   @default("USD")
  type            TxType
  status          TxStatus
  stripePaymentId String?  @unique
  metadata        Json?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payout {
  id               String       @id @default(cuid())
  developerId      String
  amount           Float
  currency         String       @default("USD")
  status           PayoutStatus @default(PENDING)
  stripeTransferId String?      @unique
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  developer        User         @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@index([developerId])
}

model DeveloperPlan {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tier                 DevTier  @default(STARTER)
  creditsIncluded      Int
  creditsUsed          Int      @default(0)
  billingCycleStart    DateTime
  billingCycleEnd      DateTime
  stripeSubscriptionId String?
  stripePriceId        String?
  autoReloadEnabled    Boolean  @default(true)
  autoReloadAmount     Int      @default(2000)
  overageRate          Decimal  @default(0.005)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPlan {
  id                   String   @id @default(cuid())
  userId               String   @unique
  tier                 UserTier @default(FREE_USER)
  creditsIncluded      Int
  creditsUsed          Int      @default(0)
  workflowRunsIncluded Int      @default(2)
  workflowRunsUsed     Int      @default(0)
  billingCycleStart    DateTime
  billingCycleEnd      DateTime
  stripeSubscriptionId String?
  stripePriceId        String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id             String      @id @default(cuid())
  userId         String
  webletId       String
  developerId    String
  sessionId      String?
  workflowId     String?
  tokensIn       Int
  tokensOut      Int
  modelId        String
  toolCalls      Json?
  creditsCharged Int
  estimatedCost  Decimal
  source         UsageSource
  parentRecordId String?
  createdAt      DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([developerId, createdAt])
  @@index([webletId, createdAt])
}

model WebletMCPServer {
  id               String      @id @default(cuid())
  webletId         String
  serverUrl        String
  label            String
  description      String?
  iconUrl          String?
  authType         MCPAuthType @default(NONE)
  authToken        String?
  tools            Json?
  isActive         Boolean     @default(true)
  catalogId        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  requiresUserAuth Boolean     @default(false)
  weblet           Weblet      @relation(fields: [webletId], references: [id], onDelete: Cascade)

  @@unique([webletId, serverUrl])
  @@index([webletId])
}

enum UserRole {
  USER
  DEVELOPER
  ADMIN
}

enum WebletCategory {
  WRITING
  CODE
  DATA_ANALYSIS
  MARKETING
  EDUCATION
  CUSTOMER_SUPPORT
  RESEARCH
  CREATIVE
  PRODUCTIVITY
  FINANCE
  HEALTH
  LEGAL
  OTHER
}

enum AccessType {
  FREE
  SUBSCRIBERS_ONLY
}

enum FlowMode {
  SEQUENTIAL
  HYBRID
  PARALLEL
}

enum VersionStatus {
  DRAFT
  TESTING
  ACTIVE
  ROLLED_BACK
  ARCHIVED
}

enum SubStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

enum TxType {
  SUBSCRIPTION_PAYMENT
  PAYOUT
  REFUND
}

enum TxStatus {
  PENDING
  COMPLETED
  FAILED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum DevTier {
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum UserTier {
  FREE_USER
  PLUS
  POWER
}

enum UsageSource {
  DIRECT_CHAT
  COMPOSABILITY
  WORKFLOW
  ORCHESTRATION
  RSIL
}

enum MCPAuthType {
  NONE
  API_KEY
  BEARER_TOKEN
  OAUTH
}
