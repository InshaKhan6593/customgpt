NEXTAUTH_URL=http://localhost:3000
# IMPORTANT: Generate a secure secret (e.g., using `openssl rand -base64 32`) and paste it below.
AUTH_SECRET=your_auth_secret_here

# PostgreSQL connection string from Neon.
# Format: postgres://username:password@hostname/database_name?sslmode=require
DATABASE_URL=your_neon_postgres_url_here

# Resend API Key for magic link emails
RESEND_API_KEY=your_resend_api_key_here

# OAuth Providers (optional — for social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenAI (for knowledge embeddings in Segment 04+)
OPENAI_API_KEY=
